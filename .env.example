# HTTP Server
SEARCH_HTTP_PORT=8081

# OpenSearch
SEARCH_OPENSEARCH_URL=http://localhost:9200
SEARCH_OPENSEARCH_USERNAME=
SEARCH_OPENSEARCH_PASSWORD=
# Leave username/password empty for local Docker (DISABLE_SECURITY_PLUGIN=true)
SEARCH_OPENSEARCH_TIMEOUT=5s

# Query Understanding Service (QUS)
SEARCH_QUS_URL=http://localhost:8080
SEARCH_QUS_TIMEOUT=3s

# Config
SEARCH_CONFIG_DIR=configs
